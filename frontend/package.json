{
  "name": "trydelta-frontend",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "node ../node_modules/next/dist/bin/next dev",
    "prebuild": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "node ../node_modules/next/dist/bin/next build",
    "postbuild": "node -e \"const fs=require('fs');const p='.next/BUILD_ID';if(!fs.existsSync(p)) {console.error('Missing .next/BUILD_ID');process.exit(1);}const m=JSON.parse(fs.readFileSync('.next/routes-manifest.json','utf8'));if(!('dataRoutes' in m)) {console.error('routes-manifest missing dataRoutes');process.exit(1);}console.log('Next build manifest ok');\"",
    "start": "node ../node_modules/next/dist/bin/next start",
    "lint": "node ../node_modules/next/dist/bin/next lint",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "framer-motion": "^12.34.5",
    "next": "15.5.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "24.0.1",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.12",
    "typescript": "5.8.3"
  }
}
